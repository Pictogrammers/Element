{
  "compilerOptions": {
    "target": "ESNext",
    "module": "es2022",
    "lib": ["ES2023", "ES6", "DOM"],
    "declaration": true,
    "strictNullChecks": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "typeRoots": ["src"],
    "strictPropertyInitialization": false,
  },
  "include": [
    "src/element.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}